<View>

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  DOCUMENT IMAGE                                                         -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->

  <Image name="image" value="$image" zoom="true" zoomControl="true"
         rotateControl="true" brightnessControl="true" contrastControl="true"/>


  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  PAGE-LEVEL LABELS  (collapsible — set once per page)                  -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->

  <View collapsible="true" collapsed="true">
    <Header value="PAGE-LEVEL LABELS"/>

    <Header value="Page Type"/>
    <Choices name="page_type" toName="image" choice="single">
      <Choice value="form"/>
      <Choice value="letter"/>
      <Choice value="note"/>
      <Choice value="invoice"/>
      <Choice value="budget"/>
      <Choice value="legal_document"/>
      <Choice value="other"/>
    </Choices>

    <Header value="Page Layout"/>
    <Choices name="page_layout" toName="image" choice="single" showInLine="true">
      <Choice value="single_column"/>
      <Choice value="two_column"/>
      <Choice value="multi_column"/>
      <Choice value="complex"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Page Integrity"/>
    <Choices name="page_integrity" toName="image" choice="single" showInLine="true">
      <Choice value="clean"/>
      <Choice value="worn"/>
      <Choice value="damaged"/>
      <Choice value="other"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Scan Quality"/>
    <Choices name="scan_quality" toName="image" choice="single" showInLine="true">
      <Choice value="good"/>
      <Choice value="degraded"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Page Rotation"/>
    <Choices name="page_orientation" toName="image" choice="single" showInLine="true">
      <Choice value="none"/>
      <Choice value="rotated_1_45"/>
      <Choice value="rotated_46_90"/>
      <Choice value="rotated_91_180"/>
      <Choice value="rotated_neg1_45"/>
      <Choice value="rotated_neg46_90"/>
      <Choice value="rotated_neg91_180"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Decade Written"/>
    <Choices name="decade_written" toName="image" choice="single" showInLine="true">
      <Choice value="pre_1950"/>
      <Choice value="1950s"/>
      <Choice value="1960s"/>
      <Choice value="1970s"/>
      <Choice value="1980s"/>
      <Choice value="1990s"/>
      <Choice value="2000s"/>
      <Choice value="2010s"/>
      <Choice value="2020s"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Watermark"/>
    <Choices name="watermark" toName="image" choice="single" showInLine="true">
      <Choice value="true"/>
      <Choice value="false"/>
    </Choices>

    <Header value="Coloured Background"/>
    <Choices name="coloured_background" toName="image" choice="single" showInLine="true">
      <Choice value="true"/>
      <Choice value="false"/>
    </Choices>

    <Header value="Handwritten Text Proportion (approximate % of text content that is handwritten)"/>
    <Choices name="handwritten_proportion" toName="image" choice="single" showInLine="true">
      <Choice value="none_0"/>
      <Choice value="minimal_1_25"/>
      <Choice value="partial_26_50"/>
      <Choice value="majority_51_75"/>
      <Choice value="high_76_100"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Page Artifacts"/>
    <Choices name="page_artifacts" toName="image" choice="multiple" showInLine="true">
      <Choice value="skew"/>
      <Choice value="warping"/>
      <Choice value="scan_lines_or_band"/>
      <Choice value="low_contrast"/>
      <Choice value="blurry"/>
      <Choice value="noise_grain"/>
      <Choice value="overprint_or_overlay"/>
      <Choice value="show_through"/>
      <Choice value="other"/>
    </Choices>
  </View>


  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!--  REGION-LEVEL LABELS  (collapsible — open by default)                  -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->

  <View collapsible="true" collapsed="false">
    <Header value="REGION-LEVEL LABELS"/>

    <Header value="Draw a bounding box around each region, then fill in its attributes below."/>

    <RectangleLabels name="bbox" toName="image" strokeWidth="2">
      <Label value="text_region" background="#4A90D9"/>
      <Label value="image_text"  background="#7B68EE"/>
      <Label value="table"       background="#E67E22"/>
      <Label value="form"        background="#27AE60"/>
      <Label value="symbol"      background="#E74C3C"/>
      <Label value="stamp"       background="#8E44AD"/>
      <Label value="image"       background="#95A5A6"/>
      <Label value="unknown"     background="#BDC3C7"/>
    </RectangleLabels>

    <TextArea name="transcription" toName="image"
              editable="true" perRegion="true"
              placeholder="Transcribe the exact text in this region"
              rows="4"/>

    <Header value="Reading Order"/>
    <Number name="reading_order" toName="image" perRegion="true"
            placeholder="Reading order position (1, 2, 3 ...)"/>

    <Header value="Region Rotation"/>
    <Choices name="region_rotation" toName="image" choice="single"
             perRegion="true" showInLine="true">
      <Choice value="none"/>
      <Choice value="rotated_1_45"/>
      <Choice value="rotated_46_90"/>
      <Choice value="rotated_91_180"/>
      <Choice value="rotated_neg1_45"/>
      <Choice value="rotated_neg46_90"/>
      <Choice value="rotated_neg91_180"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Text Type"/>
    <Choices name="text_type" toName="image" choice="single"
             perRegion="true" showInLine="false">
      <Choice value="printed_plain"/>
      <Choice value="printed_typewritten"/>
      <Choice value="printed_graphic_logo"/>
      <Choice value="printed_stamp"/>
      <Choice value="handwritten_cursive"/>
      <Choice value="handwritten_print"/>
      <Choice value="handwritten_other"/>
      <Choice value="signature"/>
      <Choice value="mixed_print_handwritten"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Handwriting Slant"/>
    <Choices name="handwriting_slant" toName="image" choice="single"
             perRegion="true" showInLine="true">
      <Choice value="upright"/>
      <Choice value="slanted"/>
      <Choice value="unknown"/>
    </Choices>

    <Header value="Legibility"/>
    <Choices name="legibility" toName="image" choice="single"
             perRegion="true" showInLine="true">
      <Choice value="clear"/>
      <Choice value="faint"/>
      <Choice value="partially_obscured"/>
      <Choice value="completely_obscured"/>
    </Choices>

    <Header value="Region Artifacts"/>
    <Choices name="region_artifacts" toName="image" choice="multiple"
             perRegion="true" showInLine="true">
      <Choice value="skew"/>
      <Choice value="warping"/>
      <Choice value="scan_lines_or_band"/>
      <Choice value="low_contrast"/>
      <Choice value="blurry"/>
      <Choice value="noise_grain"/>
      <Choice value="overprint_or_overlay"/>
      <Choice value="show_through"/>
      <Choice value="other"/>
    </Choices>


    <!-- Table attributes — collapsed by default -->
    <View collapsible="true" collapsed="true">
      <Header value="TABLE ATTRIBUTES — complete only for table regions"/>

      <Header value="Layout"/>
      <Choices name="table_layout" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="vertical"/>
        <Choice value="horizontal"/>
        <Choice value="other"/>
        <Choice value="unknown"/>
      </Choices>

      <Header value="Merged Cells"/>
      <Choices name="table_merged_cells" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="true"/>
        <Choice value="false"/>
      </Choices>

      <Header value="Borders"/>
      <Choices name="table_borders" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="full_line"/>
        <Choice value="less_line"/>
        <Choice value="fewer_line"/>
        <Choice value="wireless_line"/>
        <Choice value="other"/>
        <Choice value="unknown"/>
      </Choices>

      <Header value="Coloured Cells"/>
      <Choices name="table_coloured_cells" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="true"/>
        <Choice value="false"/>
      </Choices>
    </View>


    <!-- Form attributes — collapsed by default -->
    <View collapsible="true" collapsed="true">
      <Header value="FORM ATTRIBUTES — complete only for form regions"/>

      <Header value="Fill Status"/>
      <Choices name="form_field_status" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="filled"/>
        <Choice value="partially_filled"/>
        <Choice value="unfilled"/>
      </Choices>

      <Header value="Text Style"/>
      <Choices name="form_text_style" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="purely_printed"/>
        <Choice value="purely_handwritten"/>
        <Choice value="mixed"/>
        <Choice value="unknown"/>
      </Choices>
    </View>


    <!-- Symbol attributes — collapsed by default -->
    <View collapsible="true" collapsed="true">
      <Header value="SYMBOL ATTRIBUTES — complete only for symbol regions"/>

      <Header value="Type"/>
      <Choices name="symbol_type" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="checkbox"/>
        <Choice value="radio_button"/>
        <Choice value="other"/>
      </Choices>

      <Header value="State"/>
      <Choices name="symbol_state" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="checked"/>
        <Choice value="unchecked"/>
        <Choice value="unknown"/>
      </Choices>
    </View>


    <!-- Stamp attributes — collapsed by default -->
    <View collapsible="true" collapsed="true">
      <Header value="STAMP ATTRIBUTES — complete only for stamp regions"/>

      <Header value="Shape"/>
      <Choices name="stamp_shape" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="circular"/>
        <Choice value="rectangular"/>
        <Choice value="oval"/>
        <Choice value="irregular"/>
        <Choice value="other"/>
      </Choices>

      <Header value="Legibility"/>
      <Choices name="stamp_legibility" toName="image" choice="single"
               perRegion="true" showInLine="true">
        <Choice value="clear"/>
        <Choice value="partial"/>
        <Choice value="illegible"/>
      </Choices>
    </View>

  </View>

</View>
